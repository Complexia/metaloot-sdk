{
  "name": "@metaloot/sdk",
  "version": "0.3.0",
  "description": "Unified Metaloot SDK for games: hosted 2D, 3D, audio and animation assets, player auth, and multiplayer rooms.",
  "type": "module",
  "license": "MIT",
  "author": "Metaloot",
  "homepage": "https://metaloot.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Complexia/metaloot-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Complexia/metaloot-sdk/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./assets": {
      "types": "./dist/assets.d.ts",
      "import": "./dist/assets.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./multiplayer": {
      "types": "./dist/multiplayer.d.ts",
      "import": "./dist/multiplayer.js"
    },
    "./three": {
      "types": "./dist/three.d.ts",
      "import": "./dist/three.js"
    },
    "./water": {
      "types": "./dist/water.d.ts",
      "import": "./dist/water.js"
    },
    "./babylon": {
      "types": "./dist/babylon.d.ts",
      "import": "./dist/babylon.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "test": "npm run build && node --test tests/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "metaloot",
    "games",
    "3d-assets",
    "2d-assets",
    "game-audio",
    "animation",
    "glb",
    "multiplayer",
    "auth",
    "browser-games"
  ],
  "devDependencies": {
    "@babylonjs/core": "^8.0.0",
    "@babylonjs/loaders": "^8.0.0",
    "@types/node": "^20.19.0",
    "@types/three": "^0.178.0",
    "three": "^0.178.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@babylonjs/core": ">=7.0.0",
    "@babylonjs/loaders": ">=7.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "@babylonjs/core": { "optional": true },
    "@babylonjs/loaders": { "optional": true },
    "three": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  }
}
